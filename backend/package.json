{
  "name": "elite-digital-academy-backend",
  "version": "1.0.0",
  "description": "Backend for Elite Digital Academy Course Platform",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "npm run dev:clean",
    "dev:clean": "node scripts/killPort.js 5000 && nodemon --config nodemon.json server.js",
    "notes:one": "node scripts/processOneNoteImage.js",
    "course:c:fromNotes": "node scripts/createCProgrammingCourseFromEnhancedNotes.js",
    "seed:hwi": "node scripts/seedHackWithInfyCourse.js && node scripts/auditHackWithInfyStarters.js",
    "seed:hwi:reset": "set HWI_RESET=1 && node scripts/seedHackWithInfyCourse.js && node scripts/auditHackWithInfyStarters.js",
    "audit:hwi": "node scripts/auditHackWithInfyStarters.js",
    "seed:hwi:verify": "node scripts/seedHackWithInfyCourse.js && node scripts/auditHackWithInfyStarters.js",
    "smoke:hwi": "node scripts/smokeJudge0HackWithInfyStarters.js",
    "smoke:hwi:quick": "node scripts/smokeJudge0HackWithInfyStarters.js --max 10 --continue",
    "smoke:hwi:all": "node scripts/smokeJudge0HackWithInfyStarters.js --continue"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.91",
    "aws-sdk": "^2.1498.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "doflow-root": "file:../..",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "nodemailer": "^6.9.7",
    "pdf-parse": "^1.1.4",
    "pdfjs-dist": "^5.4.624",
    "razorpay": "^2.9.2",
    "tesseract.js": "^7.0.0",
    "validator": "^13.11.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
